---
import { getCollection } from 'astro:content';
import { useTranslations, getAlternateLanguagePath } from '../i18n/utils';

interface Props {
  lang?: 'it' | 'en';
}

const { lang = 'it' } = Astro.props;
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
const copyrightText = t('footer.copyright').replace('2024', currentYear.toString());

// Query services dynamically to list them in the footer
const servicesCollection = await getCollection('services', ({ data }) => {
  return data.lang === lang;
});

const servicesList = servicesCollection.map(service => {
  const slugName = service.slug.split('/').pop() || service.slug;
  return {
    title: service.data.title,
    url: lang === 'it' ? `/servizi/${slugName}` : `/en/services/${slugName}`,
    weight: service.data.weight || 0,
  };
}).sort((a, b) => a.weight - b.weight);

// Alternate language URL mapping
const currentPath = Astro.url.pathname;
const alternatePath = getAlternateLanguagePath(currentPath, lang);


const alternateLang = lang === 'it' ? 'en' : 'it';
const switchLangLabel = lang === 'it' ? 'Passa a English' : 'Switch to Italiano';
const darkModeLabel = lang === 'it' ? 'Attiva tema scuro' : 'Enable dark mode';
const lightModeLabel = lang === 'it' ? 'Attiva tema chiaro' : 'Enable light mode';

const socialLinks = [
  {
    name: 'Linkedin',
    url: 'https://www.linkedin.com/company/pavesa/',
    icon: 'fab fa-linkedin',
    color: 'hover:text-[#0077b5]'
  },
  {
    name: 'Facebook',
    url: 'https://www.facebook.com/Pavesa-Srl-1532544440319105',
    icon: 'fab fa-facebook',
    color: 'hover:text-[#4460ae]'
  },
  {
    name: 'Instagram',
    url: 'https://www.instagram.com/pavesasrl/?hl=it',
    icon: 'fab fa-instagram',
    color: 'hover:text-[#cd4378]'
  },
  {
    name: 'Email',
    url: 'mailto:info@pavesasrl.it',
    icon: 'fas fa-envelope',
    color: 'hover:text-pavesa-yellow'
  },
];
---

<footer class="bg-[#151515] dark:bg-[#070707] text-gray-300 border-t border-black/10 dark:border-white/5 py-12 mt-16 transition-colors">
  <div class="container mx-auto px-4 max-w-6xl">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      <!-- Col 1: Brand Info -->
      <div class="space-y-4">
        <a href={lang === 'it' ? '/' : '/en/'} class="block rounded focus:outline-none">
          <img
            src="/images/logo/logo_pavesa.png"
            alt="PA.VE.SA. srl"
            class="h-10 w-auto brightness-0 invert"
          />
        </a>
        <p class="text-xs text-gray-400 leading-relaxed">
          {lang === 'it' 
            ? "Soluzioni industriali all'avanguardia in tutta Italia: pavimenti in resina, impermeabilizzazioni in poliurea, verniciature e sabbiature."
            : "Cutting-edge industrial solutions across Italy: resin flooring, polyurea waterproofing, painting, and sandblasting."}
        </p>
        <!-- Socials -->
        <div class="flex space-x-4 pt-2">
          {socialLinks.map(link => (
            <a
              href={link.url}
              target={link.name !== 'Email' ? '_blank' : undefined}
              rel={link.name !== 'Email' ? 'noopener noreferrer' : undefined}
              class={`text-2xl text-gray-400 transition-colors duration-200 ${link.color}`}
              aria-label={link.name}
            >
              <i class={link.icon}></i>
            </a>
          ))}
        </div>
      </div>

      <!-- Col 2: Quick Links -->
      <div class="space-y-4">
        <h4 class="text-white font-bold text-sm uppercase tracking-wider">{lang === 'it' ? 'Navigazione' : 'Navigation'}</h4>
        <ul class="space-y-2.5 text-xs">
          <li><a href={lang === 'it' ? '/' : '/en/'} class="hover:text-pavesa-yellow transition-colors">{lang === 'it' ? 'Home' : 'Home'}</a></li>
          <li><a href={lang === 'it' ? '/azienda' : '/en/about'} class="hover:text-pavesa-yellow transition-colors">{lang === 'it' ? 'Chi Siamo' : 'About Us'}</a></li>
          <li><a href={lang === 'it' ? '/contatti' : '/en/contact'} class="hover:text-pavesa-yellow transition-colors">{lang === 'it' ? 'Contatti' : 'Contact Us'}</a></li>
          <li><a href={lang === 'it' ? '/privacy' : '/en/privacy'} class="hover:text-pavesa-yellow transition-colors">{t('footer.privacy')}</a></li>
        </ul>
      </div>

      <!-- Col 3: Services -->
      <div class="space-y-4">
        <h4 class="text-white font-bold text-sm uppercase tracking-wider">{lang === 'it' ? 'Servizi' : 'Services'}</h4>
        <ul class="space-y-2.5 text-xs">
          {servicesList.map(service => (
            <li>
              <a href={service.url} class="hover:text-pavesa-yellow transition-colors">
                {service.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Utility & Certs -->
      <div class="space-y-4">
        <h4 class="text-white font-bold text-sm uppercase tracking-wider">{lang === 'it' ? 'Lingua & Tema' : 'Language & Theme'}</h4>
        
        <!-- Language Switcher & Dark Mode Toggle -->
        <div class="flex items-center space-x-3 bg-white/5 p-2 rounded-lg border border-white/5 w-fit">
          <!-- Language Switcher -->
          <a
            href={alternatePath}
            class="flex items-center justify-center min-w-[36px] h-9 px-2 text-xs font-bold text-gray-300 hover:text-pavesa-yellow transition-colors rounded hover:bg-white/5"
            aria-label={switchLangLabel}
            hreflang={alternateLang}
          >
            <i class="fas fa-globe mr-1.5 text-xs"></i>
            <span class="uppercase">{alternateLang}</span>
          </a>

          <span class="w-[1px] h-6 bg-white/10"></span>

          <!-- Dark Mode Toggle -->
          <button
            id="dark-mode-toggle-footer"
            type="button"
            class="flex items-center justify-center min-w-[36px] h-9 px-2 text-xs font-bold text-gray-300 hover:text-pavesa-yellow transition-colors rounded hover:bg-white/5 cursor-pointer"
            aria-label={darkModeLabel}
            data-dark-label={darkModeLabel}
            data-light-label={lightModeLabel}
          >
            <i class="fas fa-moon mr-1.5 text-xs" id="footer-dark-mode-icon"></i>
            <span class="dark-mode-text" id="footer-dark-mode-text">{lang === 'it' ? 'Tema' : 'Theme'}</span>
          </button>
        </div>

        <!-- Certifications -->
        <h4 class="text-white font-bold text-xs uppercase tracking-wider pt-2">{lang === 'it' ? 'Certificazioni' : 'Certifications'}</h4>
        <div class="flex items-center space-x-3">
          <div class="bg-white/5 border border-white/5 text-gray-300 px-3 py-1.5 rounded text-[10px] font-bold tracking-wider">
            SOA
          </div>
          <div class="bg-white/5 border border-white/5 text-gray-300 px-3 py-1.5 rounded text-[10px] font-bold tracking-wider">
            ISO 9001:2015
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom copyright -->
    <div class="border-t border-white/5 pt-8 text-center text-xs text-gray-500 space-y-2">
      <div>{copyrightText}</div>
      <div>{t('footer.vat')} | {t('footer.cciaa')}</div>
    </div>

  </div>
</footer>

<script>
  function initFooterDarkMode() {
    const btn = document.getElementById('dark-mode-toggle-footer');
    const html = document.documentElement;
    if (!btn) return;

    const icon = document.getElementById('footer-dark-mode-icon');
    const text = document.getElementById('footer-dark-mode-text');

    function updateFooterButtonState(theme: string) {
      const isDark = theme === 'dark';
      if (icon) {
        icon.className = isDark ? 'fas fa-sun mr-1.5 text-xs' : 'fas fa-moon mr-1.5 text-xs';
      }
      if (text) {
        text.textContent = isDark 
          ? (html.lang === 'it' ? 'Chiaro' : 'Light')
          : (html.lang === 'it' ? 'Scuro' : 'Dark');
      }
      const label = isDark ? btn?.dataset.lightLabel : btn?.dataset.darkLabel;
      if (label) btn?.setAttribute('aria-label', label);
    }

    function setTheme(theme: string) {
      if (theme === 'dark') {
        html.classList.add('dark');
      } else {
        html.classList.remove('dark');
      }
      localStorage.setItem('theme', theme);
      updateFooterButtonState(theme);
    }

    btn.addEventListener('click', () => {
      const current = html.classList.contains('dark') ? 'dark' : 'light';
      setTheme(current === 'dark' ? 'light' : 'dark');
    });

    // Update button state initially based on loaded theme class on <html>
    const initialTheme = html.classList.contains('dark') ? 'dark' : 'light';
    updateFooterButtonState(initialTheme);
  }

  // Initialize on load and transition
  document.addEventListener('astro:page-load', initFooterDarkMode);
</script>
