---
/**
 * ServiceGrid Component
 *
 * Griglia servizi con:
 * - Immagini ottimizzate con skeleton
 * - Accessibilità migliorata (ARIA, semantica)
 * - i18n completo
 * - Touch target minimi 44px
 */
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';
import OptimizedImage from './OptimizedImage.astro';

interface Props {
  lang?: 'it' | 'en';
  showTitle?: boolean;
}

const { lang = 'it', showTitle = true } = Astro.props;
const t = useTranslations(lang);

// Query services from content collection dynamically based on language
const rawServices = await getCollection('services', ({ data }) => {
  return data.lang === lang;
});

const services = rawServices.map(service => {
  // Extract slug name without locale prefix
  const slugName = service.slug.split('/').pop() || service.slug;
  return {
    slug: slugName,
    title: service.data.title,
    summary: service.data.summary,
    banner: service.data.banner,
    alt: service.data.alt,
    weight: service.data.weight,
  };
}).sort((a, b) => a.weight - b.weight);

const servicesBasePath = lang === 'it' ? '/servizi' : '/en/services';

// Testi localizzati
const sectionTitle = lang === 'it' ? 'i nostri servizi' : 'our services';
const readMoreText = lang === 'it' ? 'leggi di più' : 'read more';
const goToPageText = lang === 'it' ? 'vai alla pagina dedicata' : 'go to dedicated page';
---

<section class="py-16 bg-white dark:bg-[#121212] transition-colors" aria-label={!showTitle ? sectionTitle : undefined} aria-labelledby={showTitle ? "services-heading" : undefined}>
  <div class="container mx-auto px-4">
    <!-- Section Title -->
    {showTitle && (
      <div class="text-center mb-12">
        <h2 id="services-heading" class="heading-border text-2xl md:text-3xl font-bold">
          {sectionTitle}
        </h2>
      </div>
    )}

    <!-- Services Grid -->
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 list-none p-0 m-0" role="list">
      {services.map((service, index) => (
        <li>
          <article class="group relative overflow-hidden rounded-xl border border-black/[0.06] dark:border-white/[0.08] shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 h-full flex flex-col bg-white dark:bg-[#1e1e1e]">
            <!-- Image Container (Clean & Zoom Only) -->
            <div class="relative h-48 overflow-hidden">
              <OptimizedImage
                src={service.banner}
                alt={service.alt}
                width={400}
                height={208}
                class="service-card-image w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                aspectRatio="400 / 208"
                loading={index < 2 ? 'eager' : 'lazy'}
                fetchpriority={index < 2 ? 'high' : 'auto'}
              />
            </div>

            <!-- Content Card -->
            <div class="p-6 flex-1 flex flex-col justify-between">
              <div>
                <!-- Semantic Title containing the only Stretched Link -->
                <h3 class="text-lg font-bold text-pavesa-dark dark:text-gray-100 flex items-center justify-between mb-2">
                  <a
                    href={`${servicesBasePath}/${service.slug}`}
                    class="hover:text-pavesa-yellow-accessible dark:hover:text-pavesa-yellow transition-colors after:absolute after:inset-0 after:z-10 focus:outline-none"
                    aria-label={`${service.title} - ${goToPageText}`}
                  >
                    {service.title}
                  </a>
                  <!-- Sleek visual arrow icon indicator -->
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5 text-pavesa-yellow-accessible dark:text-pavesa-yellow transform transition-transform duration-300 group-hover:translate-x-1.5 shrink-0 ml-2"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </h3>
                <p class="text-pavesa-text-secondary dark:text-gray-400 line-clamp-3 text-sm leading-relaxed">
                  {service.summary}
                </p>
              </div>
            </div>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Immagine service card con zoom */
  article :global(.optimized-image-wrapper) {
    height: 100%;
  }

  article :global(.service-card-image) {
    transition: transform var(--duration-slow, 400ms) var(--ease-out, ease-out);
  }

  .group:hover :global(.service-card-image) {
    transform: scale(1.1);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    article {
      transition: none;
    }

    article :global(.service-card-image) {
      transition: none;
    }

    .group:hover :global(.service-card-image) {
      transform: none;
    }
  }
</style>
