---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?: 'it' | 'en';
}

const { lang = 'it' } = Astro.props;
const t = useTranslations(lang);

const ctaContent = {
  it: {
    title: t('cta.experience'),
    linkText: t('cta.contact'),
    linkUrl: '/contatti',
  },
  en: {
    title: t('cta.experience'),
    link_text: t('cta.contact'),
    link_url: '/en/contact',
  }
};

const content = lang === 'it' ? {
  title: 'Più di 10 anni di esperienza',
  linkText: 'contattaci',
  linkUrl: '/contatti'
} : {
  title: 'More than 10 years of experience',
  linkText: 'contact us',
  linkUrl: '/en/contact'
};
---

<section class="group relative py-24 text-center overflow-hidden">
  <!-- Background Image with Zoom -->
  <div 
    class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" 
    style="background-image: url('/images/backgrounds/fixed-background.jpg');"
  ></div>
  <!-- Dark Overlay -->
  <div class="absolute inset-0 bg-black/65 transition-colors duration-300 group-hover:bg-black/55 z-10" aria-hidden="true"></div>

  <div class="container mx-auto px-4 relative z-20">
    <h3 class="text-2xl md:text-4xl font-bold uppercase text-white text-shadow-lg inline-flex items-center justify-center gap-3">
      <a
        href={lang === 'it' ? '/contatti' : '/en/contact'}
        class="hover:text-pavesa-yellow transition-colors after:absolute after:inset-0 after:z-30 focus:outline-none"
      >
        {lang === 'it' ? 'Più di 10 anni di esperienza' : 'More than 10 years of experience'}
      </a>
      <!-- Sleek Arrow Icon -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6 md:h-8 md:w-8 text-pavesa-yellow transform transition-transform duration-300 group-hover:translate-x-2 shrink-0"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2.5"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </h3>
  </div>
</section>
