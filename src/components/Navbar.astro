---
/**
 * Navbar Component
 *
 * Navigazione principale con supporto completo accessibilità:
 * - ARIA landmarks e ruoli
 * - Navigazione keyboard
 * - Focus management
 * - Stato attivo con aria-current
 * - Language switcher
 * - Dark mode toggle
 */

import type { Locale } from '../types';
import { useTranslations } from '../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang?: Locale;
}

const { lang = 'it' } = Astro.props;
const t = useTranslations(lang);

const menuItems = [
  { name: 'Home', url: lang === 'it' ? '/' : '/en', identifier: 'home' },
  { name: lang === 'it' ? 'Azienda' : 'About', url: lang === 'it' ? '/azienda' : '/en/about', identifier: 'azienda' },
  { name: lang === 'it' ? 'Servizi' : 'Services', url: lang === 'it' ? '/servizi' : '/en/services', identifier: 'servizi' },
  { name: lang === 'it' ? 'Contatti' : 'Contact', url: lang === 'it' ? '/contatti' : '/en/contact', identifier: 'contatti' },
];

const servicesCollection = await getCollection('services', ({ data }) => {
  return data.lang === lang;
});

const servicesList = servicesCollection.map(service => {
  const slugName = service.slug.split('/').pop() || service.slug;
  return {
    title: service.data.title,
    url: lang === 'it' ? `/servizi/${slugName}` : `/en/services/${slugName}`,
    weight: service.data.weight || 0,
  };
}).sort((a, b) => a.weight - b.weight);

// Get current path to determine active menu item
const currentPath = Astro.url.pathname;

/**
 * Determina se un menu item è attivo
 * Gestisce correttamente home, pagine esatte e child routes
 */
function isActive(itemUrl: string, identifier: string): boolean {
  // Normalizza i path (rimuovi trailing slash per confronto)
  const normalizedCurrent = currentPath.replace(/\/$/, '') || '/';
  const normalizedItem = itemUrl.replace(/\/$/, '') || '/';

  // Home ha bisogno di match esatto
  if (identifier === 'home') {
    return normalizedCurrent === '/' || normalizedCurrent === '/en';
  }

  // Match esatto
  if (normalizedCurrent === normalizedItem) {
    return true;
  }

  // Check per child routes (es. /servizi/pavimenti matcha /servizi)
  return normalizedCurrent.startsWith(normalizedItem + '/');
}



const navLabel = lang === 'it' ? 'Navigazione principale' : 'Main navigation';
const homeLabel = lang === 'it' ? 'PA.VE.SA. - Torna alla home' : 'PA.VE.SA. - Go to homepage';
const alternateLang = lang === 'it' ? 'en' : 'it';
const alternateLangLabel = lang === 'it' ? 'English' : 'Italiano';
const switchLangLabel = lang === 'it' ? 'Passa a English' : 'Switch to Italiano';
const darkModeLabel = lang === 'it' ? 'Attiva tema scuro' : 'Enable dark mode';
const lightModeLabel = lang === 'it' ? 'Attiva tema chiaro' : 'Enable light mode';
---

<header id="main-header" class="sticky top-0 z-50 backdrop-blur-md bg-white/80 dark:bg-[#1e1e1e]/80 border-b border-black/5 dark:border-white/5 shadow-sm transition-all duration-300">
  <nav class="container mx-auto px-4" aria-label={navLabel}>
    <div class="flex items-center justify-between py-4">
      <!-- Logo -->
      <a
        href={lang === 'it' ? '/' : '/en/'}
        class="flex items-center rounded"
        aria-label={homeLabel}
      >
        <img
          src="/images/logo/logo_pavesa.png"
          alt="PA.VE.SA. srl"
          class="h-12 w-auto logo-default block"
          width="180"
          height="48"
        />
        <img
          src="/images/logo/favicon-quad_mtsvvu.png"
          alt="PA.VE.SA. srl"
          class="h-12 w-auto logo-transparent hidden"
          width="48"
          height="48"
        />
      </a>

      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center space-x-6">
        <ul class="flex items-center space-x-8" role="menubar">
          {menuItems.map(item => {
            const active = isActive(item.url, item.identifier);
            if (item.identifier === 'servizi') {
              return (
                <li role="none" class="relative group dropdown-container flex items-center h-12">
                  <button
                    type="button"
                    aria-haspopup="true"
                    aria-expanded="false"
                    class={`
                      inline-flex items-center gap-1 h-12 text-pavesa-dark dark:text-gray-200 hover:text-pavesa-yellow
                      transition-colors duration-200 font-medium uppercase cursor-pointer
                      tracking-wide text-sm rounded focus:outline-none
                      ${active ? 'text-pavesa-yellow' : ''}
                    `}
                  >
                    {item.name}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                    {active && (
                      <span class="absolute bottom-0 left-0 right-[20px] h-[3px] bg-pavesa-yellow" aria-hidden="true"></span>
                    )}
                  </button>
                  
                  {/* Dropdown Menu */}
                  <div 
                    class="absolute top-full right-0 mt-1 w-64 bg-white dark:bg-[#1e1e1e] border border-black/5 dark:border-white/5 rounded-lg shadow-xl py-2 opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200 z-50"
                    role="menu"
                  >
                    {servicesList.map(service => (
                      <a
                        href={service.url}
                        role="menuitem"
                        class="block px-4 py-2.5 text-sm text-pavesa-dark dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-pavesa-yellow dark:hover:text-pavesa-yellow transition-colors"
                      >
                        {service.title}
                      </a>
                    ))}
                  </div>
                </li>
              );
            }
            return (
              <li role="none" class="flex items-center h-12">
                <a
                  href={item.url}
                  role="menuitem"
                  aria-current={active ? 'page' : undefined}
                  class={`
                    relative inline-flex items-center h-12 text-pavesa-dark dark:text-gray-200 hover:text-pavesa-yellow
                    transition-colors duration-200 font-medium uppercase
                    tracking-wide text-sm rounded
                    ${active ? 'text-pavesa-yellow' : ''}
                  `}
                >
                  {item.name}
                  {active && (
                    <span class="absolute bottom-0 left-0 right-0 h-[3px] bg-pavesa-yellow" aria-hidden="true"></span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="md:hidden p-2 min-w-[44px] min-h-[44px] flex items-center justify-center text-2xl text-pavesa-yellow dark:text-pavesa-yellow rounded"
        aria-label={t('nav.toggle')}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <i class="fas fa-bars" aria-hidden="true"></i>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden pb-4 border-t border-gray-200 dark:border-gray-700 mt-2"
      role="menu"
      aria-labelledby="mobile-menu-toggle"
    >
      <ul class="flex flex-col space-y-2 pt-4">
        {menuItems.map(item => {
          const active = isActive(item.url, item.identifier);
          if (item.identifier === 'servizi') {
            return (
              <li role="none" class="px-4 py-2 border-b border-gray-100 dark:border-gray-800">
                <span class="block text-xs font-bold text-pavesa-gray dark:text-gray-400 uppercase tracking-wider mb-2">
                  {item.name}
                </span>
                <ul class="pl-2 space-y-1">
                  {servicesList.map(service => {
                    const isServiceActive = currentPath === service.url || currentPath === service.url + '/';
                    return (
                      <li role="none">
                        <a
                          href={service.url}
                          role="menuitem"
                          aria-current={isServiceActive ? 'page' : undefined}
                          class={`
                            block py-2 px-3 text-sm text-pavesa-dark dark:text-gray-300 hover:text-pavesa-yellow
                            transition-colors duration-200 uppercase tracking-wide rounded
                            ${isServiceActive ? 'text-pavesa-yellow font-bold bg-gray-50 dark:bg-gray-700' : ''}
                          `}
                        >
                          {service.title}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </li>
            );
          }
          return (
            <li role="none">
              <a
                href={item.url}
                role="menuitem"
                aria-current={active ? 'page' : undefined}
                class={`
                  block py-2 px-4 text-pavesa-dark dark:text-gray-200 hover:text-pavesa-yellow
                  hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-200 uppercase tracking-wide
                  rounded
                  ${active ? 'text-pavesa-yellow font-bold bg-gray-50 dark:bg-gray-700' : ''}
                `}
              >
                {item.name}
              </a>
            </li>
          );
        })}
      </ul>

    </div>
  </nav>
</header>

<script>
  function initMobileMenu() {
    const menuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = menuToggle?.querySelector('i');

    if (!menuToggle || !mobileMenu) return;

    function openMenu() {
      mobileMenu.classList.remove('hidden');
      menuToggle.setAttribute('aria-expanded', 'true');
      menuIcon?.classList.remove('fa-bars');
      menuIcon?.classList.add('fa-times');

      // Focus primo link del menu per accessibilità
      const firstLink = mobileMenu.querySelector('a');
      firstLink?.focus();
    }

    function closeMenu() {
      mobileMenu.classList.add('hidden');
      menuToggle.setAttribute('aria-expanded', 'false');
      menuIcon?.classList.remove('fa-times');
      menuIcon?.classList.add('fa-bars');
    }

    menuToggle.addEventListener('click', () => {
      const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
      if (isExpanded) {
        closeMenu();
      } else {
        openMenu();
      }
      // Dispatch scroll event to update navbar transparency
      window.dispatchEvent(new Event('scroll'));
    });

    // Chiudi menu al click su un link
    const mobileMenuLinks = mobileMenu.querySelectorAll('a');
    mobileMenuLinks.forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // Chiudi menu con tasto Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuToggle.getAttribute('aria-expanded') === 'true') {
        closeMenu();
        menuToggle.focus();
      }
    });

    // Trap focus nel menu mobile quando aperto
    mobileMenu.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;

      const focusableElements = mobileMenu.querySelectorAll('a[href]');
      const firstElement = focusableElements[0] as HTMLElement;
      const lastElement = focusableElements[focusableElements.length - 1] as HTMLElement;

      if (e.shiftKey && document.activeElement === firstElement) {
        e.preventDefault();
        menuToggle.focus();
      } else if (!e.shiftKey && document.activeElement === lastElement) {
        e.preventDefault();
        menuToggle.focus();
      }
    });
  }

  let scrollListener: (() => void) | null = null;

  function initNavbarTransparency() {
    const header = document.getElementById('main-header');
    const hasCarousel = !!document.querySelector('.hero-carousel');
    
    if (!header) return;

    // Clean up existing listener if any
    if (scrollListener) {
      window.removeEventListener('scroll', scrollListener);
      scrollListener = null;
    }

    if (!hasCarousel) {
      header.classList.remove('is-transparent');
      return;
    }

    const handleScroll = () => {
      const mobileMenu = document.getElementById('mobile-menu');
      const isMobileMenuOpen = mobileMenu && !mobileMenu.classList.contains('hidden');

      if (window.scrollY > 50 || isMobileMenuOpen) {
        header.classList.remove('is-transparent');
      } else {
        header.classList.add('is-transparent');
      }
    };

    scrollListener = handleScroll;
    handleScroll();
    window.addEventListener('scroll', handleScroll, { passive: true });
  }

  // Inizializza al caricamento pagina e dopo le transition
  document.addEventListener('astro:page-load', () => {
    initMobileMenu();
    initNavbarTransparency();
  });
</script>

<style>
  #main-header.is-transparent {
    position: fixed;
    width: 100%;
    background-color: transparent !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    border-bottom-color: transparent !important;
    box-shadow: none !important;
  }

  /* In transparent mode, menu links, utility buttons, and icons should be white on desktop */
  @media (min-width: 768px) {
    #main-header.is-transparent a:not([aria-current="page"]):not(:hover),
    #main-header.is-transparent button:not(:hover),
    #main-header.is-transparent i:not(:hover) {
      color: rgba(255, 255, 255, 0.9) !important;
    }
    #main-header.is-transparent a[aria-current="page"] {
      color: var(--pavesa-yellow) !important;
    }
  }

  /* For dark mode toggle and globe icon */
  #main-header.is-transparent #dark-mode-toggle,
  #main-header.is-transparent #dark-mode-toggle-mobile,
  #main-header.is-transparent .fa-globe {
    color: rgba(255, 255, 255, 0.9) !important;
  }

  /* Logo transparent toggling styles */
  #main-header.is-transparent .logo-default {
    display: none !important;
  }
  #main-header.is-transparent .logo-transparent {
    display: block !important;
  }
  #main-header:not(.is-transparent) .logo-default {
    display: block !important;
  }
  #main-header:not(.is-transparent) .logo-transparent {
    display: none !important;
  }
</style>



