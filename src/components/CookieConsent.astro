---
interface Props {
  lang?: 'it' | 'en';
}

const { lang = 'it' } = Astro.props;

const content = {
  it: {
    message: "Questo sito utilizza cookie tecnici e, previo tuo consenso, cookie analitici di terze parti per raccogliere dati statistici in forma aggregata. Cliccando su 'Accetta tutti' acconsenti all'uso di tutti i cookie. Cliccando su 'Rifiuta tutti' o sulla 'X' in alto a destra, continuerai la navigazione con i soli cookie tecnici necessari.",
    acceptAll: "Accetta tutti",
    declineAll: "Rifiuta tutti",
    customize: "Personalizza",
    savePreferences: "Salva preferenze",
    policy: "Leggi la Cookie Policy",
    policyLink: "/privacy",
    preferencesTitle: "Preferenze Cookie",
    necessaryTitle: "Cookie Tecnici (Necessari)",
    necessaryDesc: "Indispensabili per il corretto funzionamento del sito, non disattivabili.",
    analyticsTitle: "Cookie Statistici (Google Analytics)",
    analyticsDesc: "Raccolgono informazioni in forma anonima e aggregata sull'utilizzo del sito.",
    marketingTitle: "Cookie di Profilazione e Marketing",
    marketingDesc: "Utilizzati per tracciare la navigazione degli utenti e creare profili personalizzati."
  },
  en: {
    message: "This website uses technical cookies and, with your consent, third-party analytical cookies to collect aggregated statistical data. By clicking 'Accept all', you consent to the use of all cookies. By clicking 'Reject all' or the 'X' in the top-right, you will continue browsing with only necessary technical cookies.",
    acceptAll: "Accept all",
    declineAll: "Reject all",
    customize: "Customize",
    savePreferences: "Save preferences",
    policy: "Read Cookie Policy",
    policyLink: "/en/privacy",
    preferencesTitle: "Cookie Preferences",
    necessaryTitle: "Technical Cookies (Necessary)",
    necessaryDesc: "Essential for the correct functioning of the website, cannot be disabled.",
    analyticsTitle: "Statistical Cookies (Google Analytics)",
    analyticsDesc: "Collect anonymous and aggregated information on site usage.",
    marketingTitle: "Profiling and Marketing Cookies",
    marketingDesc: "Used to track user navigation and create personalized profiles."
  }
};

const text = lang === 'it' ? content.it : content.en;
---

<div
  id="cookie-consent"
  class="fixed bottom-6 right-6 left-6 md:left-auto md:max-w-md z-50 p-6 bg-white dark:bg-[#1e1e1e] rounded-xl shadow-2xl border border-gray-100 dark:border-gray-800 transform translate-y-full opacity-0 transition-all duration-500 ease-out hidden"
  role="alertdialog"
  aria-live="polite"
  aria-label="Cookie Consent"
>
  <!-- Close Button (X) - Equivalent to Rejecting All non-necessary cookies -->
  <button
    id="cookie-close-x"
    class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors p-1"
    aria-label="Chiudi e rifiuta cookie non necessari / Close and reject non-necessary cookies"
  >
    <i class="fas fa-times text-lg"></i>
  </button>

  <div class="flex flex-col space-y-4">
    <!-- Icon & Title -->
    <div class="flex items-center space-x-3">
      <div class="flex-shrink-0 text-pavesa-yellow">
        <i class="fas fa-cookie-bite text-2xl"></i>
      </div>
      <h2 class="text-lg font-bold text-pavesa-secondary dark:text-gray-100">
        Cookie Policy
      </h2>
    </div>

    <!-- Main Message -->
    <div class="text-sm text-pavesa-secondary dark:text-gray-300 leading-relaxed pr-6">
      <p>
        {text.message}
      </p>
      <a href={text.policyLink} class="text-pavesa-yellow hover:underline inline-block mt-1 font-medium">
        {text.policy}
      </a>
    </div>

    <!-- Action Buttons -->
    <div id="cookie-main-actions" class="flex flex-col sm:flex-row gap-2 pt-2">
      <button
        id="cookie-decline"
        class="w-full sm:w-1/2 px-4 py-2.5 text-sm font-semibold text-gray-700 dark:text-gray-200 bg-gray-100 dark:bg-gray-800 rounded-md hover:bg-gray-200 dark:hover:bg-gray-700 transition-all text-center border border-gray-200 dark:border-gray-700 cursor-pointer"
      >
        {text.declineAll}
      </button>
      <button
        id="cookie-accept"
        class="w-full sm:w-1/2 px-4 py-2.5 text-sm font-bold text-black bg-pavesa-yellow rounded-md hover:bg-pavesa-yellow-hover transition-all text-center cursor-pointer shadow-sm"
      >
        {text.acceptAll}
      </button>
    </div>

    <!-- Customize Button -->
    <div class="text-center">
      <button
        id="cookie-toggle-customize"
        class="text-xs font-semibold text-gray-500 dark:text-gray-400 hover:text-pavesa-yellow dark:hover:text-pavesa-yellow transition-colors underline cursor-pointer"
      >
        {text.customize}
      </button>
    </div>

    <!-- Preferences Drawer (Hidden by default) -->
    <div id="cookie-preferences-drawer" class="hidden border-t border-gray-100 dark:border-gray-800 pt-4 mt-2 space-y-4">
      <h3 class="text-sm font-bold text-pavesa-secondary dark:text-gray-100">
        {text.preferencesTitle}
      </h3>

      <!-- Technical Cookies -->
      <div class="flex items-start space-x-3 text-xs bg-gray-50 dark:bg-[#181818] p-3 rounded-lg">
        <input
          type="checkbox"
          id="cookie-pref-necessary"
          checked
          disabled
          class="mt-0.5 rounded text-pavesa-yellow focus:ring-pavesa-yellow opacity-70 cursor-not-allowed"
        />
        <label for="cookie-pref-necessary" class="flex flex-col cursor-not-allowed">
          <span class="font-bold text-pavesa-secondary dark:text-gray-200">{text.necessaryTitle}</span>
          <span class="text-gray-500 dark:text-gray-400 mt-0.5">{text.necessaryDesc}</span>
        </label>
      </div>

      <!-- Analytics Cookies -->
      <div class="flex items-start space-x-3 text-xs bg-gray-50 dark:bg-[#181818] p-3 rounded-lg cursor-pointer">
        <input
          type="checkbox"
          id="cookie-pref-analytics"
          class="mt-0.5 rounded text-pavesa-yellow focus:ring-pavesa-yellow cursor-pointer"
        />
        <label for="cookie-pref-analytics" class="flex flex-col cursor-pointer select-none">
          <span class="font-bold text-pavesa-secondary dark:text-gray-200">{text.analyticsTitle}</span>
          <span class="text-gray-500 dark:text-gray-400 mt-0.5">{text.analyticsDesc}</span>
        </label>
      </div>

      <!-- Marketing Cookies -->
      <div class="flex items-start space-x-3 text-xs bg-gray-50 dark:bg-[#181818] p-3 rounded-lg cursor-pointer">
        <input
          type="checkbox"
          id="cookie-pref-marketing"
          class="mt-0.5 rounded text-pavesa-yellow focus:ring-pavesa-yellow cursor-pointer"
        />
        <label for="cookie-pref-marketing" class="flex flex-col cursor-pointer select-none">
          <span class="font-bold text-pavesa-secondary dark:text-gray-200">{text.marketingTitle}</span>
          <span class="text-gray-500 dark:text-gray-400 mt-0.5">{text.marketingDesc}</span>
        </label>
      </div>

      <!-- Save Preferences Button -->
      <button
        id="cookie-save-prefs"
        class="w-full px-4 py-2 text-sm font-bold text-black bg-pavesa-yellow rounded-md hover:bg-pavesa-yellow-hover transition-all text-center cursor-pointer"
      >
        {text.savePreferences}
      </button>
    </div>
  </div>
</div>

<script>
  function initCookieConsent() {
    const banner = document.getElementById('cookie-consent');
    const acceptAllBtn = document.getElementById('cookie-accept');
    const declineAllBtn = document.getElementById('cookie-decline');
    const closeXBtn = document.getElementById('cookie-close-x');
    const toggleCustomizeBtn = document.getElementById('cookie-toggle-customize');
    const preferencesDrawer = document.getElementById('cookie-preferences-drawer');
    const savePrefsBtn = document.getElementById('cookie-save-prefs');
    const analyticsCheckbox = document.getElementById('cookie-pref-analytics') as HTMLInputElement | null;
    const marketingCheckbox = document.getElementById('cookie-pref-marketing') as HTMLInputElement | null;

    if (!banner || !acceptAllBtn || !declineAllBtn || !closeXBtn || !toggleCustomizeBtn || !preferencesDrawer || !savePrefsBtn) return;

    // Check if user has already made a choice
    const consentRaw = localStorage.getItem('pavesa-cookie-consent');

    if (!consentRaw) {
      // Show banner after a small delay
      banner.classList.remove('hidden');
      setTimeout(() => {
        banner.classList.remove('translate-y-full', 'opacity-0');
      }, 500);
    } else {
      // If already has consent, propagate to document load just in case (e.g. for page navigations)
      try {
        const consent = JSON.parse(consentRaw);
        window.dispatchEvent(new CustomEvent('cookie-consent-ready', { detail: consent }));
      } catch (e) {
        console.error('Error parsing cookie consent options', e);
      }
    }

    function closeBanner() {
      banner?.classList.add('translate-y-full', 'opacity-0');
      setTimeout(() => {
        banner?.classList.add('hidden');
      }, 500);
    }

    function saveConsent(consentObj: { necessary: boolean; analytics: boolean; marketing: boolean }) {
      localStorage.setItem('pavesa-cookie-consent', JSON.stringify(consentObj));
      window.dispatchEvent(new CustomEvent('cookie-consent-updated', { detail: consentObj }));
      closeBanner();
    }

    // Accept All
    acceptAllBtn.addEventListener('click', () => {
      saveConsent({
        necessary: true,
        analytics: true,
        marketing: true
      });
    });

    // Reject All (only necessary cookies)
    declineAllBtn.addEventListener('click', () => {
      saveConsent({
        necessary: true,
        analytics: false,
        marketing: false
      });
    });

    // Close X (acts as Reject All)
    closeXBtn.addEventListener('click', () => {
      saveConsent({
        necessary: true,
        analytics: false,
        marketing: false
      });
    });

    // Toggle Preferences Drawer
    toggleCustomizeBtn.addEventListener('click', () => {
      if (preferencesDrawer.classList.contains('hidden')) {
        preferencesDrawer.classList.remove('hidden');
        toggleCustomizeBtn.classList.add('hidden');
      }
    });

    // Save preferences
    savePrefsBtn.addEventListener('click', () => {
      saveConsent({
        necessary: true,
        analytics: analyticsCheckbox ? analyticsCheckbox.checked : false,
        marketing: marketingCheckbox ? marketingCheckbox.checked : false
      });
    });

    // Listen to open-cookie-preferences custom event (to reopen from Privacy policy page)
    window.addEventListener('open-cookie-preferences', () => {
      // Pre-fill checkboxes based on current choice if it exists
      const currentConsent = localStorage.getItem('pavesa-cookie-consent');
      if (currentConsent) {
        try {
          const parsed = JSON.parse(currentConsent);
          if (analyticsCheckbox) analyticsCheckbox.checked = !!parsed.analytics;
          if (marketingCheckbox) marketingCheckbox.checked = !!parsed.marketing;
        } catch(e) {}
      }
      banner.classList.remove('hidden');
      preferencesDrawer.classList.remove('hidden');
      toggleCustomizeBtn.classList.add('hidden');
      setTimeout(() => {
        banner.classList.remove('translate-y-full', 'opacity-0');
      }, 50);
    });
  }

  // Init on page load
  document.addEventListener('DOMContentLoaded', initCookieConsent);
  document.addEventListener('astro:page-load', initCookieConsent);
</script>
