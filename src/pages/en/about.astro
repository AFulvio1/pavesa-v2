---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ClientLogos from '../../components/ClientLogos.astro';
---

<BaseLayout
  title="About Us - PA.VE.SA. srl"
  description="PA.VE.SA. srl - Industrial services company specialized in flooring, painting, sandblasting and waterproofing. ISO 9001:2015 certified."
  keywords={['about us', 'company', 'certifications', 'industrial services']}
  lang="en"
>
  <!-- Page Header -->
  <section class="bg-gray-100 dark:bg-[#1e1e1e] py-16 transition-colors">
    <div class="container mx-auto px-4">
      <h1 class="heading-border text-3xl md:text-4xl font-bold text-center dark:text-gray-100">
        About Us
      </h1>
    </div>
  </section>

  <!-- Company Content -->
  <section class="py-16 bg-white dark:bg-[#121212] transition-colors">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">

        <h2 class="text-2xl font-bold mb-6 text-pavesa-dark dark:text-gray-100 uppercase tracking-wide">PA.VE.SA. srl</h2>

        <p class="mb-6 text-lg leading-relaxed dark:text-gray-300">
          <strong>PA.VE.SA. srl</strong> was established in May 2008, evolving from the previous company
          <strong>P.V.S.</strong> (Pavimenti Verniciatura Sabbiatura), which had been operating successfully
          in the sector since 2005.
        </p>

        <p class="mb-6 text-lg leading-relaxed dark:text-gray-300">
          The company specializes in providing <strong>industrial services</strong> of the highest quality,
          with particular focus on:
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors">
            <h3 class="text-xl font-bold mb-3 text-pavesa-dark dark:text-gray-100 flex items-center">
              <i class="fas fa-layer-group text-pavesa-yellow mr-3"></i>
              Sandblasting
            </h3>
            <p class="text-pavesa-gray dark:text-gray-400">
              Professional sandblasting services for metal cleaning and surface preparation,
              using both dry and wet sandblasting techniques.
            </p>
          </div>

          <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors">
            <h3 class="text-xl font-bold mb-3 text-pavesa-dark dark:text-gray-100 flex items-center">
              <i class="fas fa-paint-roller text-pavesa-yellow mr-3"></i>
              Painting
            </h3>
            <p class="text-pavesa-gray dark:text-gray-400">
              Industrial painting with two-component acrylic products and other specialized coatings,
              applied using high-pressure airless systems.
            </p>
          </div>

          <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors">
            <h3 class="text-xl font-bold mb-3 text-pavesa-dark dark:text-gray-100 flex items-center">
              <i class="fas fa-flask text-pavesa-yellow mr-3"></i>
              Vitrification
            </h3>
            <p class="text-pavesa-gray dark:text-gray-400">
              Application of vitrifying products for the protection and enhancement of various surfaces,
              ensuring long-lasting durability and resistance.
            </p>
          </div>

          <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors">
            <h3 class="text-xl font-bold mb-3 text-pavesa-dark dark:text-gray-100 flex items-center">
              <i class="fas fa-road text-pavesa-yellow mr-3"></i>
              Flooring
            </h3>
            <p class="text-pavesa-gray dark:text-gray-400">
              Installation of industrial and civil flooring using flexible resins and high-performance materials,
              designed to withstand intensive use.
            </p>
          </div>
        </div>

        <h2 class="text-2xl font-bold mb-6 mt-12 text-pavesa-dark uppercase tracking-wide">Our Coverage Area</h2>

        <p class="mb-6 text-lg leading-relaxed dark:text-gray-300">
          PA.VE.SA. srl operates throughout <strong>Central and Southern Italy</strong>, with particular expertise in the following regions:
        </p>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium">Tuscany</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium">Lazio</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium">Umbria</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium">Abruzzo</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium">Marche</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium">Emilia Romagna</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium">Campania</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium">Molise</p>
          </div>
        </div>

        <h2 class="text-2xl font-bold mb-6 mt-12 text-pavesa-dark uppercase tracking-wide">Certifications</h2>

        <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors mb-8">
          <ul class="space-y-3">
            <li class="flex items-start">
              <i class="fas fa-certificate text-pavesa-yellow mt-1 mr-3"></i>
              <div>
                <strong>Master Builder Solutions SPA Certified</strong>
                <p class="text-sm text-pavesa-gray dark:text-gray-400">
                  Official certification for the application of professional products
                  <a href="https://drive.google.com/file/d/0B7xnOhIMSGbDS1V4RnRMNkFqdFE/view" target="_blank" rel="noopener noreferrer" class="text-pavesa-yellow hover:underline">
                    (view certificate)
                  </a>
                </p>
              </div>
            </li>
            <li class="flex items-start">
              <i class="fas fa-certificate text-pavesa-yellow mt-1 mr-3"></i>
              <div>
                <strong>ISO 9001:2015 Certified</strong>
                <p class="text-sm text-pavesa-gray dark:text-gray-400">
                  Quality Management System certification
                  <a href="https://drive.google.com/file/d/1pQcz7b4sKSF90WfLzD6RnVH_z_1c1-xg/view" target="_blank" rel="noopener noreferrer" class="text-pavesa-yellow hover:underline">
                    (view certificate)
                  </a>
                </p>
              </div>
            </li>
            <li class="flex items-start">
              <i class="fas fa-certificate text-pavesa-yellow mt-1 mr-3"></i>
              <div>
                <strong>Public Works Certification</strong>
                <p class="text-sm text-pavesa-gray dark:text-gray-400">
                  Authorized for public sector projects
                  <a href="https://drive.google.com/file/d/1vswsPg92mPvHCPOGbdWEPDFJdqzllG6B/view" target="_blank" rel="noopener noreferrer" class="text-pavesa-yellow hover:underline">
                    (view certificate)
                  </a>
                </p>
              </div>
            </li>
          </ul>
        </div>

        <h2 class="text-2xl font-bold mb-6 mt-12 text-pavesa-dark uppercase tracking-wide">Our Clients</h2>

        <p class="mb-6 text-lg leading-relaxed dark:text-gray-300">
          Over the years, PA.VE.SA. srl has built strong relationships with major companies across various sectors:
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
          <ul class="space-y-2">
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Trenitalia</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Bridgestone</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Leonardo SPA</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Sorgenia</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> ArcelorMittal</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Newlat Food SPA</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Cantine San Marzano</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Antica Enotria</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Cantina Frentana</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Cantina La Valentina</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Cantine Di Marzo</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Cantina Tollo</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Cantina Farnese</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Tenuta Ulisse</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Umani Ronchi</li>
          </ul>
          <ul class="space-y-2">
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Orsogna</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Formec Biffi</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Mecal</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Pezzullo</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Grotte di Castro</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> La Molisana</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Di Martino</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Stellantis</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Grifal</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Italpannelli</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Idea Concreting</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> CIR</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Cogedi</li>
            <li class="flex items-center"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> ...and many others</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- Client Logos Section -->
  <ClientLogos lang="en" />

</BaseLayout>
