---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact - PA.VE.SA. srl"
  description="Contact PA.VE.SA. srl for industrial flooring, painting, sandblasting and waterproofing services. Phone, email and office addresses."
  keywords={['contact', 'phone', 'email', 'address', 'office']}
  lang="en"
>
  <!-- Main Contact Content Section -->
  <section class="py-12 md:py-16 bg-white dark:bg-[#121212] transition-colors">
    <div class="container mx-auto px-4 max-w-6xl">
      <!-- Section Title & Intro directly in page to save space -->
      <div class="text-center mb-12">
        <h1 class="heading-border text-3xl md:text-4xl font-bold text-center dark:text-gray-100">
          Contact Us
        </h1>
        <p class="text-lg text-gray-600 dark:text-gray-400 mt-4 max-w-2xl mx-auto">
          We are at your disposal for any information, quote, or technical consultation.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        
        <!-- Left Column: Request Form -->
        <div class="space-y-6">
          <form id="contact-form" class="space-y-6 bg-gray-50 dark:bg-[#1e1e1e] p-6 md:p-8 rounded-2xl shadow-sm border border-black/5 dark:border-white/5">
            <div>
              <h2 class="text-2xl font-bold text-pavesa-dark dark:text-gray-100 border-b-2 border-pavesa-yellow inline-block pb-2 mb-2">
                Send a Message
              </h2>
              <p class="text-sm text-gray-500 dark:text-gray-400">Fill in the fields below to prepare your email request to our offices.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="nome" class="block text-sm font-semibold text-pavesa-dark dark:text-gray-200 mb-2">Full Name *</label>
                <input type="text" id="nome" required class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-[#121212] text-pavesa-dark dark:text-gray-100 focus:ring-2 focus:ring-pavesa-yellow focus:border-pavesa-yellow outline-none transition-all text-sm" />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-pavesa-dark dark:text-gray-200 mb-2">Email Address *</label>
                <input type="email" id="email" required class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-[#121212] text-pavesa-dark dark:text-gray-100 focus:ring-2 focus:ring-pavesa-yellow focus:border-pavesa-yellow outline-none transition-all text-sm" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="telefono" class="block text-sm font-semibold text-pavesa-dark dark:text-gray-200 mb-2">Phone Number</label>
                <input type="tel" id="telefono" class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-[#121212] text-pavesa-dark dark:text-gray-100 focus:ring-2 focus:ring-pavesa-yellow focus:border-pavesa-yellow outline-none transition-all text-sm" />
              </div>
              <div>
                <label for="oggetto" class="block text-sm font-semibold text-pavesa-dark dark:text-gray-200 mb-2">Subject *</label>
                <input type="text" id="oggetto" required class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-[#121212] text-pavesa-dark dark:text-gray-100 focus:ring-2 focus:ring-pavesa-yellow focus:border-pavesa-yellow outline-none transition-all text-sm" />
              </div>
            </div>

            <div>
              <label for="messaggio" class="block text-sm font-semibold text-pavesa-dark dark:text-gray-200 mb-2">Message *</label>
              <textarea id="messaggio" required rows="5" class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-[#121212] text-pavesa-dark dark:text-gray-100 focus:ring-2 focus:ring-pavesa-yellow focus:border-pavesa-yellow outline-none transition-all resize-none text-sm"></textarea>
            </div>

            <div class="flex items-start">
              <input type="checkbox" id="privacy" required class="mt-1 mr-3 h-4 w-4 rounded border-gray-300 dark:border-gray-700 text-pavesa-yellow focus:ring-pavesa-yellow" />
              <label for="privacy" class="text-xs text-gray-500 dark:text-gray-400">
                I accept the processing of personal data in accordance with the <a href="/en/privacy" class="text-pavesa-yellow hover:underline">Privacy Policy</a> *
              </label>
            </div>

            <button type="submit" class="btn-pavesa-primary w-full py-4 text-sm font-bold uppercase tracking-wider rounded transition-all cursor-pointer">
              Send Request
            </button>
          </form>
        </div>

        <!-- Right Column: Direct Info & Map -->
        <div class="space-y-6">
          <div>
            <h2 class="text-2xl font-bold mb-6 text-pavesa-dark dark:text-gray-100 border-b-2 border-pavesa-yellow inline-block pb-2">
              Contact Information
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <!-- Email Card -->
              <div class="bg-gray-50 dark:bg-[#1e1e1e] p-5 rounded-xl border border-black/5 dark:border-white/5 flex items-start group">
                <div class="bg-pavesa-yellow/10 p-2.5 rounded-lg mr-3 text-pavesa-yellow shrink-0">
                  <i class="fas fa-envelope"></i>
                </div>
                <div>
                  <h4 class="font-bold text-sm text-pavesa-dark dark:text-gray-100 mb-1">Email</h4>
                  <a href="mailto:info@pavesasrl.it" class="text-sm text-gray-600 dark:text-gray-300 hover:text-pavesa-yellow transition-colors break-all">
                    info@pavesasrl.it
                  </a>
                </div>
              </div>

              <!-- Opening Hours Card -->
              <div class="bg-gray-50 dark:bg-[#1e1e1e] p-5 rounded-xl border border-black/5 dark:border-white/5 flex items-start">
                <div class="bg-pavesa-yellow/10 p-2.5 rounded-lg mr-3 text-pavesa-yellow shrink-0">
                  <i class="fas fa-clock"></i>
                </div>
                <div>
                  <h4 class="font-bold text-sm text-pavesa-dark dark:text-gray-100 mb-1">Business Hours</h4>
                  <p class="text-sm text-gray-600 dark:text-gray-300 leading-tight">Mon - Fri: 8:00 AM - 5:00 PM</p>
                  <p class="text-red-500/80 text-xs mt-1 font-medium">Saturday and Sunday Closed</p>
                </div>
              </div>
            </div>

            <!-- Phone Card (Larger) -->
            <div class="bg-gray-50 dark:bg-[#1e1e1e] p-5 rounded-xl border border-black/5 dark:border-white/5 flex items-start mt-4">
              <div class="bg-pavesa-yellow/10 p-2.5 rounded-lg mr-3 text-pavesa-yellow shrink-0">
                <i class="fas fa-phone-alt"></i>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full">
                <div>
                  <h4 class="font-bold text-sm text-pavesa-dark dark:text-gray-100 mb-1">Office Phone</h4>
                  <a href="tel:+390875808184" class="text-sm text-gray-600 dark:text-gray-300 hover:text-pavesa-yellow block">0875 808184</a>
                  <a href="tel:+393277425486" class="text-sm text-gray-600 dark:text-gray-300 hover:text-pavesa-yellow block">327 7425486</a>
                </div>
                <div>
                  <h4 class="font-bold text-sm text-pavesa-dark dark:text-gray-100 mb-1">Technical Contacts</h4>
                  <p class="text-xs text-gray-600 dark:text-gray-300">Ercole: <a href="tel:+393477333796" class="hover:text-pavesa-yellow font-medium">347 7333796</a></p>
                  <p class="text-xs text-gray-600 dark:text-gray-300 mt-1">Nicholas: <a href="tel:+393663619031" class="hover:text-pavesa-yellow font-medium">366 3619031</a></p>
                </div>
              </div>
            </div>

            <!-- Sedi Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
              <!-- Sede Legale -->
              <div class="bg-gray-50 dark:bg-[#1e1e1e] p-5 rounded-xl border border-black/5 dark:border-white/5 flex items-start">
                <div class="bg-pavesa-yellow/10 p-2.5 rounded-lg mr-3 text-pavesa-yellow shrink-0">
                  <i class="fas fa-map-marker-alt"></i>
                </div>
                <div>
                  <h4 class="font-bold text-sm text-pavesa-dark dark:text-gray-100 mb-1">Registered Office</h4>
                  <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">Via Germania, 4<br>86034 Guglionesi (CB)</p>
                </div>
              </div>
              
              <!-- Sede Amministrativa -->
              <div class="bg-gray-50 dark:bg-[#1e1e1e] p-5 rounded-xl border border-black/5 dark:border-white/5 flex items-start">
                <div class="bg-pavesa-yellow/10 p-2.5 rounded-lg mr-3 text-pavesa-yellow shrink-0">
                  <i class="fas fa-building"></i>
                </div>
                <div>
                  <h4 class="font-bold text-sm text-pavesa-dark dark:text-gray-100 mb-1">Admin Office</h4>
                  <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">C.da piane di Larino, 90<br>86035 Larino (CB)</p>
                </div>
              </div>
            </div>

            <!-- Map Wrapper -->
            <div class="rounded-xl overflow-hidden shadow-sm border border-gray-200 dark:border-gray-800 h-[280px] mt-4">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2969.040807451273!2d14.911240315682475!3d41.91348147117792!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1330c9bd0f74bfdb%3A0x5127f532c42d82fe!2sPA.VE.SA.!5e0!3m2!1sit!2sit!4v1627315898664!5m2!1sit!2sit"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="PA.VE.SA. srl location map"
              ></iframe>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const nome = (document.getElementById('nome') as HTMLInputElement).value;
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const telefono = (document.getElementById('telefono') as HTMLInputElement).value;
      const oggetto = (document.getElementById('oggetto') as HTMLInputElement).value;
      const messaggio = (document.getElementById('messaggio') as HTMLTextAreaElement).value;
      
      const mailto = `mailto:info@pavesasrl.it?subject=${encodeURIComponent(oggetto)}&body=${encodeURIComponent(
        `Name: ${nome}\nEmail: ${email}\nPhone: ${telefono || 'N/D'}\n\nMessage:\n${messaggio}`
      )}`;
      
      window.location.href = mailto;
    });
  }

  document.addEventListener('astro:page-load', initContactForm);
</script>
