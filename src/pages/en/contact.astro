---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact - PA.VE.SA. srl"
  description="Contact PA.VE.SA. srl for industrial flooring, painting, sandblasting and waterproofing services. Phone, email and office addresses."
  keywords={['contact', 'phone', 'email', 'address', 'office']}
  lang="en"
>
  <!-- Page Header -->
  <section class="bg-gray-100 dark:bg-[#1e1e1e] py-20 transition-colors">
    <div class="container mx-auto px-4 text-center">
      <h1 class="heading-border inline-block text-4xl md:text-5xl font-bold dark:text-gray-100 mb-6">
        Contact Us
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        We are at your disposal for any information, quote, or technical consultation.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-16 bg-white dark:bg-[#121212] transition-colors">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        
        <!-- Left Column: Direct Contact -->
        <div class="space-y-8">
          <div>
            <h2 class="text-2xl font-bold mb-6 text-pavesa-dark dark:text-gray-100 border-b-2 border-pavesa-yellow inline-block pb-2">
              Get in Touch
            </h2>
            
            <!-- Email -->
            <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-xl shadow-sm hover:shadow-md transition-shadow mb-6 group">
              <div class="flex items-start">
                <div class="bg-pavesa-yellow/10 p-3 rounded-lg mr-4 group-hover:bg-pavesa-yellow group-hover:text-white transition-colors text-pavesa-yellow">
                   <i class="fas fa-envelope text-xl"></i>
                </div>
                <div>
                   <h3 class="text-lg font-bold text-pavesa-dark dark:text-gray-100 mb-1">Email Us</h3>
                   <a href="mailto:info@pavesasrl.it" class="text-lg text-gray-600 dark:text-gray-300 hover:text-pavesa-yellow transition-colors">
                     info@pavesasrl.it
                   </a>
                </div>
              </div>
            </div>

            <!-- Phones -->
            <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-xl shadow-sm hover:shadow-md transition-shadow mb-6">
              <div class="flex items-start mb-4">
                 <div class="bg-pavesa-yellow/10 p-3 rounded-lg mr-4 text-pavesa-yellow">
                   <i class="fas fa-phone-alt text-xl"></i>
                </div>
                <div>
                   <h3 class="text-lg font-bold text-pavesa-dark dark:text-gray-100">Call Us</h3>
                </div>
              </div>
              
              <div class="pl-[4.5rem] space-y-4">
                 <div>
                    <p class="text-sm text-gray-500 dark:text-gray-400 uppercase tracking-wider font-semibold">Main Office</p>
                    <a href="tel:+390875808184" class="text-gray-700 dark:text-gray-200 hover:text-pavesa-yellow block">0875 808184</a>
                    <a href="tel:+393277425486" class="text-gray-700 dark:text-gray-200 hover:text-pavesa-yellow block">327 7425486</a>
                 </div>
                 <div>
                    <p class="text-sm text-gray-500 dark:text-gray-400 uppercase tracking-wider font-semibold">Technical Contacts</p>
                    <p class="text-gray-700 dark:text-gray-200"><span class="font-medium">Ercole:</span> <a href="tel:+393477333796" class="hover:text-pavesa-yellow">347 7333796</a></p>
                    <p class="text-gray-700 dark:text-gray-200"><span class="font-medium">Nicholas:</span> <a href="tel:+393663619031" class="hover:text-pavesa-yellow">366 3619031</a></p>
                 </div>
              </div>
            </div>

            <!-- Hours -->
             <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-xl shadow-sm hover:shadow-md transition-shadow">
              <div class="flex items-start">
                <div class="bg-pavesa-yellow/10 p-3 rounded-lg mr-4 text-pavesa-yellow">
                   <i class="fas fa-clock text-xl"></i>
                </div>
                <div>
                   <h3 class="text-lg font-bold text-pavesa-dark dark:text-gray-100 mb-2">Business Hours</h3>
                   <p class="text-gray-600 dark:text-gray-300">Monday - Friday<br>8:00 AM - 5:00 PM</p>
                   <p class="text-red-500/80 text-sm mt-2 font-medium">Saturday and Sunday Closed</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Location -->
        <div class="space-y-8">
           <div>
            <h2 class="text-2xl font-bold mb-6 text-pavesa-dark dark:text-gray-100 border-b-2 border-pavesa-yellow inline-block pb-2">
              Find Us
            </h2>

             <!-- Addresses -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
               <div class="bg-gray-50 dark:bg-[#1e1e1e] p-5 rounded-xl border-l-4 border-pavesa-yellow">
                  <h4 class="font-bold text-pavesa-dark dark:text-gray-100 mb-2">Registered Office</h4>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Via Germania, 4<br>86034 Guglionesi (CB)</p>
               </div>
               <div class="bg-gray-50 dark:bg-[#1e1e1e] p-5 rounded-xl border-l-4 border-pavesa-yellow">
                  <h4 class="font-bold text-pavesa-dark dark:text-gray-100 mb-2">Admin Office</h4>
                  <p class="text-sm text-gray-600 dark:text-gray-400">C.da piane di Larino, 90<br>86035 Larino (CB)</p>
               </div>
            </div>

            <!-- Map -->
            <div class="rounded-xl overflow-hidden shadow-lg border border-gray-100 dark:border-gray-800 h-[400px]">
               <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2969.040807451273!2d14.911240315682475!3d41.91348147117792!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1330c9bd0f74bfdb%3A0x5127f532c42d82fe!2sPA.VE.SA.!5e0!3m2!1sit!2sit!4v1627315898664!5m2!1sit!2sit"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="PA.VE.SA. srl location map"
            ></iframe>
            </div>

           </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
