---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroCarousel from '../../components/HeroCarousel.astro';
import ServiceGrid from '../../components/ServiceGrid.astro';
import CTASection from '../../components/CTASection.astro';
import ClientLogos from '../../components/ClientLogos.astro';
import ProviderLogos from '../../components/ProviderLogos.astro';
---

<BaseLayout
  title="PA.VE.SA. srl - Flooring, Painting, Sandblasting"
  description="Flooring, Painting, Sandblasting and Waterproofing services. Industrial flooring in resins and polyurea, industrial painting, sandblasting and waterproofing with polyurea."
  keywords={['flooring', 'painting', 'sandblasting', 'waterproofing', 'polyurea', 'resins']}
  lang="en"
>
  <HeroCarousel lang="en" />

  <!-- Intro Section -->
  <section class="py-20 bg-gray-50 dark:bg-[#1e1e1e] transition-colors text-center">
    <div class="container mx-auto px-4 max-w-4xl">
      <span class="text-pavesa-yellow font-bold uppercase tracking-widest text-sm mb-4 block">Who We Are</span>
      <h2 class="text-3xl md:text-5xl font-bold text-pavesa-dark dark:text-gray-100 mb-6 leading-tight">
        Trusted partner for industrial solutions
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
        PA.VE.SA. srl is a leader in resin flooring, waterproofing, industrial painting, and sandblasting. Combining decades of experience with cutting-edge technology, we offer tailored solutions for every need.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <div id="services">
    <ServiceGrid lang="en" />
  </div>

  <!-- CTA Section -->
  <CTASection lang="en" />

  <!-- Client Logos -->
  <ClientLogos lang="en" />

  <!-- Provider Logos -->
  <ProviderLogos lang="en" />
</BaseLayout>
