import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroCarousel from '../../components/HeroCarousel.astro';
import ServiceGrid from '../../components/ServiceGrid.astro';
import CTASection from '../../components/CTASection.astro';
import ClientLogos from '../../components/ClientLogos.astro';
import ProviderLogos from '../../components/ProviderLogos.astro';
---

<BaseLayout
  title="PA.VE.SA. srl | Industrial Flooring, Polyurea and Vitrification"
  description="PA.VE.SA. srl implements industrial resin flooring, spray-applied polyurea waterproofing, vitrification of food cisterns, and industrial sandblasting across Italy."
  keywords={['flooring', 'painting', 'sandblasting', 'waterproofing', 'polyurea', 'resins', 'vitrification', 'haccp']}
  lang="en"
>
  <HeroCarousel lang="en" />

  <!-- Intro Section -->
  <section class="py-20 bg-gray-50 dark:bg-[#1e1e1e] transition-colors text-center">
    <div class="container mx-auto px-4 max-w-4xl">
      <span class="text-pavesa-yellow font-bold uppercase tracking-widest text-sm mb-4 block">Who We Are</span>
      <h2 class="text-3xl md:text-5xl font-bold text-pavesa-dark dark:text-gray-100 mb-6 leading-tight">
        Cutting-Edge Industrial Solutions for Large Facilities and Wineries
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
        Thanks to our strong partnerships with global leaders like **Master Builders Solutions** and **Sika**, we deliver HACCP-certified industrial flooring, anti-corrosive coatings, and continuous spray-applied polyurea waterproofing for national organizations including Trenitalia, Leonardo, Bridgestone, and premier agricultural enterprises in Italy.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <div id="services">
    <ServiceGrid lang="en" />
  </div>

  <!-- CTA Section -->
  <CTASection lang="en" />

  <!-- Client Logos -->
  <ClientLogos lang="en" />

  <!-- Provider Logos -->
  <ProviderLogos lang="en" />
</BaseLayout>
