---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceGrid from '../../components/ServiceGrid.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout
  title="I Nostri Servizi - PA.VE.SA. srl"
  description="Scopri tutti i servizi offerti da PA.VE.SA. srl: pavimentazioni industriali, impermeabilizzazione con poliurea, verniciatura industriale e sabbiatura professionale."
  keywords={['servizi', 'pavimenti industriali', 'impermeabilizzazione', 'verniciatura', 'sabbiatura', 'poliurea']}
  lang="it"
>
  <!-- Page Header -->
  <section class="bg-gray-100 dark:bg-[#1e1e1e] py-16 transition-colors">
    <div class="container mx-auto px-4">
      <h1 class="heading-border text-3xl md:text-4xl font-bold text-center dark:text-gray-100">
        I Nostri Servizi
      </h1>
      <p class="text-center mt-6 text-lg text-pavesa-gray dark:text-gray-400 max-w-3xl mx-auto">
        PA.VE.SA. srl offre servizi professionali di alta qualità per l'industria e il settore privato.
        Specializzati in pavimentazioni, impermeabilizzazione, verniciatura e sabbiatura.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <ServiceGrid lang="it" />

  <!-- CTA Section -->
  <CTASection lang="it" />
</BaseLayout>
