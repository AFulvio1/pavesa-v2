export async function getStaticPaths() {
  const services = await getCollection('services', ({ id }) => {
    return id.startsWith('it/');
  });

  return services.map(service => ({
    params: { slug: service.slug.replace('it/', '') },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await service.render();
const { title, description, keywords, banner, alt } = service.data;

// Ottieni lo slug corrente
const currentSlug = service.slug.replace('it/', '');
const galleryData = galleriesConfig[currentSlug];

// Ottieni gli altri servizi per la sidebar
const allServices = await getCollection('services', ({ id }) => {
  return id.startsWith('it/');
});

const otherServices = allServices
  .filter(s => s.slug.replace('it/', '') !== currentSlug)
  .map(s => {
    const slugName = s.slug.replace('it/', '');
    return {
      title: s.data.title,
      url: `/servizi/${slugName}`
    };
  });
---

<BaseLayout
  title={`${title} - PA.VE.SA. srl`}
  description={description}
  keywords={keywords}
  lang="it"
>


  <!-- Breadcrumb -->
  <div class="bg-gray-100 dark:bg-[#1e1e1e] py-3 transition-colors">
    <div class="container mx-auto px-4">
      <nav class="text-sm">
        <ol class="flex items-center space-x-2 text-pavesa-gray dark:text-gray-400">
          <li>
            <a href="/" class="hover:text-pavesa-yellow transition-colors">Home</a>
          </li>
          <li>
            <i class="fas fa-angle-right"></i>
          </li>
          <li>
            <a href="/#servizi" class="hover:text-pavesa-yellow transition-colors">Servizi</a>
          </li>
          <li>
            <i class="fas fa-angle-right"></i>
          </li>
          <li class="text-pavesa-dark dark:text-gray-100 font-medium">
            {title}
          </li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- Content Section -->
  <section class="py-12 bg-white dark:bg-[#121212] transition-colors">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <!-- Title -->
          <div class="mb-8">
            <h1 class="heading-border text-3xl md:text-4xl font-bold dark:text-gray-100">
              {title}
            </h1>
          </div>
          <!-- Service Content -->
          <article class="prose prose-lg max-w-none dark:prose-invert service-content">
            <Content />
          </article>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <aside class="space-y-8 lg:sticky lg:top-24">
            <!-- Altri Servizi Card -->
            <div class="bg-gray-50 dark:bg-[#1e1e1e] border border-black/5 dark:border-white/5 rounded-xl p-6 shadow-sm">
              <h3 class="text-lg font-bold text-pavesa-dark dark:text-gray-100 uppercase tracking-wider border-b-2 border-pavesa-yellow pb-2 mb-4">
                Altri Servizi
              </h3>
              <ul class="space-y-2.5">
                {otherServices.map(item => (
                  <li>
                    <a
                      href={item.url}
                      class="flex items-center text-sm font-medium text-pavesa-dark dark:text-gray-300 hover:text-pavesa-yellow dark:hover:text-pavesa-yellow transition-colors duration-200"
                    >
                      <i class="fas fa-chevron-right text-xs mr-2 text-pavesa-yellow"></i>
                      {item.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Certificazioni & Qualità Card -->
            <div class="bg-gray-50 dark:bg-[#1e1e1e] border border-black/5 dark:border-white/5 rounded-xl p-6 shadow-sm">
              <h3 class="text-lg font-bold text-pavesa-dark dark:text-gray-100 uppercase tracking-wider border-b-2 border-pavesa-yellow pb-2 mb-4">
                Perché Sceglierci
              </h3>
              <ul class="space-y-4">
                <li class="flex items-start">
                  <span class="flex-shrink-0 w-8 h-8 rounded-full bg-pavesa-yellow/10 flex items-center justify-center text-pavesa-yellow mr-3 mt-0.5">
                    <i class="fas fa-certificate text-sm"></i>
                  </span>
                  <div>
                    <h4 class="text-sm font-bold text-pavesa-dark dark:text-gray-100">Certificazione SOA</h4>
                    <p class="text-xs text-pavesa-gray dark:text-gray-400 mt-1">Abilitazione all'esecuzione di opere pubbliche di rilievo.</p>
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="flex-shrink-0 w-8 h-8 rounded-full bg-pavesa-yellow/10 flex items-center justify-center text-pavesa-yellow mr-3 mt-0.5">
                    <i class="fas fa-users-gear text-sm"></i>
                  </span>
                  <div>
                    <h4 class="text-sm font-bold text-pavesa-dark dark:text-gray-100">Esperienza Decennale</h4>
                    <p class="text-xs text-pavesa-gray dark:text-gray-400 mt-1">Oltre 10 anni di specializzazione in soluzioni industriali.</p>
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="flex-shrink-0 w-8 h-8 rounded-full bg-pavesa-yellow/10 flex items-center justify-center text-pavesa-yellow mr-3 mt-0.5">
                    <i class="fas fa-handshake text-sm"></i>
                  </span>
                  <div>
                    <h4 class="text-sm font-bold text-pavesa-dark dark:text-gray-100">Partner Ufficiali</h4>
                    <p class="text-xs text-pavesa-gray dark:text-gray-400 mt-1">Utilizzo esclusivo di formulati certificati Sika e Master Builders.</p>
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="flex-shrink-0 w-8 h-8 rounded-full bg-pavesa-yellow/10 flex items-center justify-center text-pavesa-yellow mr-3 mt-0.5">
                    <i class="fas fa-truck-fast text-sm"></i>
                  </span>
                  <div>
                    <h4 class="text-sm font-bold text-pavesa-dark dark:text-gray-100">Copertura Nazionale</h4>
                    <p class="text-xs text-pavesa-gray dark:text-gray-400 mt-1">Interventi tempestivi in tutta Italia con mezzi propri.</p>
                  </div>
                </li>
              </ul>
            </div>

            <!-- Contact Card -->
            <div class="bg-pavesa-dark dark:bg-[#1a1a1a] text-white rounded-xl p-6 shadow-sm border border-white/5 relative overflow-hidden">
              <div class="absolute -right-12 -bottom-12 w-36 h-36 bg-pavesa-yellow/10 rounded-full blur-xl"></div>
              <h3 class="text-lg font-bold uppercase tracking-wider mb-2 relative z-10 text-white">
                Richiedi un Preventivo
              </h3>
              <p class="text-xs text-gray-300 mb-5 leading-relaxed relative z-10">
                Hai bisogno di una soluzione personalizzata per la tua azienda? I nostri tecnici sono a tua completa disposizione.
              </p>
              <a
                href="/contatti"
                class="inline-flex items-center justify-center w-full py-3 px-4 bg-pavesa-yellow hover:bg-pavesa-yellow-accessible text-pavesa-dark font-bold rounded-lg transition-colors duration-200 uppercase tracking-wider text-xs relative z-10"
              >
                Contattaci Ora
                <i class="fas fa-arrow-right ml-2"></i>
              </a>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <!-- Work Gallery Section -->
  {galleryData && (
    <section class="py-16 bg-gray-50 dark:bg-[#1e1e1e] transition-colors">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="heading-border text-2xl md:text-3xl font-bold dark:text-gray-100">
            {galleryData.title}
          </h2>
        </div>

        {galleryData.galleries.map((gallery) => (
          gallery.type === 'triple' ? (
            <WorkGallery
              title={gallery.workTitle}
              imgPrima={gallery.images.prima}
              imgDurante={gallery.images.durante!}
              imgDopo={gallery.images.dopo}
              altPrima={`${gallery.alt} - Prima`}
              altDurante={`${gallery.alt} - Durante`}
              altDopo={`${gallery.alt} - Dopo`}
              lang="it"
            />
          ) : (
            <WorkDouble
              title={gallery.workTitle}
              imgPrima={gallery.images.prima}
              imgDopo={gallery.images.dopo}
              altPrima={`${gallery.alt} - Prima`}
              altDopo={`${gallery.alt} - Dopo`}
              lang="it"
            />
          )
        ))}
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <CTASection lang="it" />
</BaseLayout>

<style>
  /* Prose styling for markdown content */
  .prose {
    color: var(--pavesa-text-secondary);
    font-size: 1.125rem;
    line-height: 1.8;
  }

  :global(.dark) .prose {
    color: #cbd5e1;
  }

  /* Headings Main */
  .prose h2 {
    color: var(--pavesa-text-primary);
    font-size: 2rem;
    font-weight: 700;
    margin-top: 3.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--pavesa-yellow);
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  :global(.dark) .prose h2 {
    color: #f1f5f9;
  }

  /* Subheadings */
  .prose h3 {
    color: var(--pavesa-text-primary);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: 0.025em;
  }

  :global(.dark) .prose h3 {
    color: #e2e8f0;
  }

  .prose h4 {
    color: var(--pavesa-text-primary);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  :global(.dark) .prose h4 {
    color: #e2e8f0;
  }

  /* Body Text */
  .prose p {
    margin-bottom: 1.5rem;
    max-width: 65ch; /* Optimal reading length */
  }

  /* Lists */
  .prose ul {
    list-style-type: none;
    margin: 1.5rem 0;
    padding-left: 0;
  }

  .prose ul li {
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .prose ul li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    background-color: var(--pavesa-yellow);
    border-radius: 50%;
  }

  .prose strong {
    color: var(--pavesa-text-primary);
    font-weight: 700;
  }

  :global(.dark) .prose strong {
    color: #f8fafc;
  }

  .prose a {
    color: var(--pavesa-yellow-accessible);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.2s;
  }

  .prose a:hover {
    color: var(--pavesa-yellow);
  }

  :global(.dark) .prose a {
    color: var(--pavesa-yellow);
  }

  /* Accordion Styles */
  .prose :global(.accordion-header) {
    transition: color 0.2s ease-in-out, border-color 0.2s ease-in-out;
    margin-top: 1.5rem !important;
    margin-bottom: 0 !important;
  }
  .prose :global(.accordion-header.active) {
    border-bottom-color: var(--pavesa-yellow) !important;
    color: var(--pavesa-yellow-accessible) !important;
  }
  :global(.dark) .prose :global(.accordion-header.active) {
    color: var(--pavesa-yellow) !important;
  }
  .prose :global(.accordion-panel) {
    transition: max-height 0.3s ease-in-out, opacity 0.3s ease-in-out, padding 0.3s ease-in-out;
  }

  /* Nested Accordion Styles */
  .prose :global(.nested-panel) {
    transition: max-height 0.2s ease-in-out, opacity 0.2s ease-in-out;
  }
  .prose :global(.nested-header.active) {
    color: var(--pavesa-yellow-accessible) !important;
  }
  :global(.dark) .prose :global(.nested-header.active) {
    color: var(--pavesa-yellow) !important;
  }
  .prose :global(.nested-accordion) {
    padding-left: 0 !important;
  }
  .prose :global(.nested-accordion::before) {
    display: none !important;
  }
</style>

<script>
  function initServiceAccordions() {
    const content = document.querySelector('.service-content');
    if (!content) return;

    const headings = content.querySelectorAll('h3');
    headings.forEach((heading, index) => {
      // Prevent double-initialization
      if (heading.classList.contains('accordion-header')) return;

      const titleText = heading.innerHTML;
      heading.innerHTML = `<span class="accordion-title font-bold text-lg md:text-xl text-pavesa-dark dark:text-gray-100 group-hover:text-pavesa-yellow transition-colors">${titleText}</span>`;

      // Setup classes
      heading.className = 'accordion-header group flex items-center justify-between cursor-pointer py-4 border-b border-black/10 dark:border-white/10 select-none text-left w-full';

      // Chevron Icon
      const iconContainer = document.createElement('span');
      iconContainer.className = 'flex-shrink-0 w-8 h-8 rounded-full bg-black/5 dark:bg-white/5 flex items-center justify-center transition-colors duration-200 group-hover:bg-pavesa-yellow/10 ml-4';
      iconContainer.innerHTML = '<i class="fas fa-chevron-down text-xs text-pavesa-gray group-hover:text-pavesa-yellow transition-transform duration-200"></i>';
      heading.appendChild(iconContainer);

      const icon = iconContainer.querySelector('i');

      // Collect sibling elements until the next H3
      const contentNodes: Element[] = [];
      let next = heading.nextElementSibling;
      while (next && next.tagName !== 'H3' && next.tagName !== 'H2') {
        contentNodes.push(next);
        next = next.nextElementSibling;
      }

      // Create panel wrapper
      const panel = document.createElement('div');
      panel.className = 'accordion-panel overflow-hidden transition-all duration-300 max-h-0 opacity-0';

      // Insert panel
      heading.parentNode?.insertBefore(panel, heading.nextSibling);
      contentNodes.forEach(node => panel.appendChild(node));

      // Parse nested accordions inside the panel
      const listItems = panel.querySelectorAll('ul > li');
      listItems.forEach(li => {
        const strong = li.querySelector('strong');
        if (strong && (li.firstElementChild === strong || li.firstElementChild?.contains(strong))) {
          li.classList.add('nested-accordion', 'border-b', 'border-black/5', 'dark:border-white/5', 'pb-2.5', 'mb-2.5', 'list-none');

          const subHeader = document.createElement('div');
          subHeader.className = 'nested-header flex items-center justify-between cursor-pointer py-1.5 font-semibold text-pavesa-dark dark:text-gray-200 group/sub select-none text-sm md:text-base';
          
          strong.parentNode?.insertBefore(subHeader, strong);
          subHeader.appendChild(strong);

          const subIcon = document.createElement('i');
          subIcon.className = 'fas fa-chevron-down text-[10px] text-pavesa-gray group-hover/sub:text-pavesa-yellow transition-transform duration-200 ml-2';
          subHeader.appendChild(subIcon);

          const subContentNodes: Node[] = [];
          let child = subHeader.nextSibling;
          while (child) {
            subContentNodes.push(child);
            child = child.nextSibling;
          }

          const subPanel = document.createElement('div');
          subPanel.className = 'nested-panel overflow-hidden transition-all duration-200 max-h-0 opacity-0 text-sm leading-relaxed text-pavesa-gray dark:text-gray-400 mt-1';
          li.appendChild(subPanel);

          subContentNodes.forEach(node => {
            if (node.nodeType === Node.TEXT_NODE && node.nodeValue) {
              node.nodeValue = node.nodeValue.replace(/^[:\s\-\–\—]+/g, '');
            }
            subPanel.appendChild(node);
          });

          subHeader.addEventListener('click', (e) => {
            e.stopPropagation();
            const isSubOpen = subHeader.classList.contains('active');
            if (isSubOpen) {
              subHeader.classList.remove('active');
              subIcon.classList.remove('rotate-180');
              subPanel.style.maxHeight = '0';
              subPanel.style.opacity = '0';
            } else {
              subHeader.classList.add('active');
              subIcon.classList.add('rotate-180');
              subPanel.style.maxHeight = subPanel.scrollHeight + 20 + 'px';
              subPanel.style.opacity = '1';
              
              if (panel.style.maxHeight !== 'none') {
                panel.style.maxHeight = panel.scrollHeight + subPanel.scrollHeight + 50 + 'px';
              }
            }
          });
        }
      });

      // Open the first accordion section by default
      if (index === 0) {
        heading.classList.add('active');
        icon?.classList.add('rotate-180');
        iconContainer.classList.add('bg-pavesa-yellow/10');
        icon?.classList.replace('text-pavesa-gray', 'text-pavesa-yellow');
        panel.classList.add('py-4');
        setTimeout(() => {
          panel.style.maxHeight = panel.scrollHeight + 50 + 'px';
          panel.style.opacity = '1';
        }, 100);
      }

      // Event listener
      heading.addEventListener('click', () => {
        const isOpen = heading.classList.contains('active');
        if (isOpen) {
          heading.classList.remove('active');
          icon?.classList.remove('rotate-180');
          iconContainer.classList.remove('bg-pavesa-yellow/10');
          icon?.classList.replace('text-pavesa-yellow', 'text-pavesa-gray');
          panel.style.maxHeight = '0';
          panel.style.opacity = '0';
          panel.classList.remove('py-4');
        } else {
          heading.classList.add('active');
          icon?.classList.add('rotate-180');
          iconContainer.classList.add('bg-pavesa-yellow/10');
          icon?.classList.replace('text-pavesa-gray', 'text-pavesa-yellow');
          panel.classList.add('py-4');
          panel.style.maxHeight = panel.scrollHeight + 50 + 'px';
          panel.style.opacity = '1';
        }
      });
    });
  }

  // Load and swap support for Astro View Transitions
  document.addEventListener('astro:page-load', initServiceAccordions);
</script>
