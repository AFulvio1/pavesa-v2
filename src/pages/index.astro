---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTASection from '../components/CTASection.astro';
import ClientLogos from '../components/ClientLogos.astro';
import ProviderLogos from '../components/ProviderLogos.astro';
---

<BaseLayout
  title="PA.VE.SA. srl | Pavimenti Industriali, Poliurea e Vetrificazione"
  description="PA.VE.SA. srl realizza pavimenti industriali in resina, impermeabilizzazioni in poliurea a spruzzo, vetrificazione vasche alimentari e sabbiature industriali in tutta Italia."
  keywords={['pavimenti', 'verniciatura', 'sabbiatura', 'impermeabilizzazione', 'poliurea', 'resine', 'vetrificazione', 'haccp', 'siliconatura']}
  lang="it"
>
  <!-- Hero Carousel -->
  <HeroCarousel lang="it" />

  <!-- Intro Section -->
  <section class="py-20 bg-gray-50 dark:bg-[#1e1e1e] transition-colors text-center">
    <div class="container mx-auto px-4 max-w-4xl">
      <span class="text-pavesa-yellow font-bold uppercase tracking-widest text-sm mb-4 block">Chi Siamo</span>
      <h2 class="text-3xl md:text-5xl font-bold text-pavesa-dark dark:text-gray-100 mb-6 leading-tight">
        Soluzioni Industriali all'Avanguardia per Grandi Impianti e Cantine Vitivinicole
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
        Grazie alla partnership consolidata con leader mondiali come **Master Builders Solutions** e **Sika**, realizziamo pavimentazioni industriali certificate HACCP, rivestimenti anticorrosivi ed impermeabilizzazioni continue in poliurea a spruzzo per clienti di rilievo nazionale come Trenitalia, Leonardo, Bridgestone e prestigiose cantine vitivinicole del Centro-Sud.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <div id="servizi">
    <ServiceGrid lang="it" />
  </div>

  <!-- CTA Section -->
  <CTASection lang="it" />

  <!-- Client Logos -->
  <ClientLogos lang="it" />

  <!-- Provider Logos -->
  <ProviderLogos lang="it" />
</BaseLayout>
