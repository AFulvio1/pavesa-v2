---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTASection from '../components/CTASection.astro';
import ClientLogos from '../components/ClientLogos.astro';
import ProviderLogos from '../components/ProviderLogos.astro';
---

<BaseLayout
  title="PA.VE.SA. srl - Pavimenti, Verniciatura, Sabbiatura"
  description="Pavimenti, Verniciatura, Sabbiatura e Impermeabilizzazione per l'industria e il privato"
  keywords={['pavimenti', 'verniciatura', 'sabbiatura', 'impermeabilizzazione', 'poliurea', 'resine']}
  lang="it"
>
  <!-- Hero Carousel -->
  <HeroCarousel lang="it" />

  <!-- Intro Section -->
  <section class="py-20 bg-gray-50 dark:bg-[#1e1e1e] transition-colors text-center">
    <div class="container mx-auto px-4 max-w-4xl">
      <span class="text-pavesa-yellow font-bold uppercase tracking-widest text-sm mb-4 block">Chi Siamo</span>
      <h2 class="text-3xl md:text-5xl font-bold text-pavesa-dark dark:text-gray-100 mb-6 leading-tight">
        Il partner di fiducia per le lavorazioni industriali
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
        PA.VE.SA. srl è leader nel settore delle pavimentazioni in resina, impermeabilizzazioni, verniciature e sabbiature. Unendo esperienza decennale e tecnologie all'avanguardia, offriamo soluzioni su misura per ogni esigenza.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <div id="servizi">
    <ServiceGrid lang="it" />
  </div>

  <!-- CTA Section -->
  <CTASection lang="it" />

  <!-- Client Logos -->
  <ClientLogos lang="it" />

  <!-- Provider Logos -->
  <ProviderLogos lang="it" />
</BaseLayout>
