---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClientLogos from '../components/ClientLogos.astro';
---

<BaseLayout
  title="Azienda - PA.VE.SA. srl"
  description="PA.VE.SA. srl - Azienda specializzata in servizi industriali: pavimentazioni, verniciature, sabbiatura e impermeabilizzazione. Certificata ISO 9001:2015."
  keywords={['chi siamo', 'azienda', 'certificazioni', 'servizi industriali']}
  lang="it"
>
  <!-- Company Content -->
  <section class="py-12 bg-white dark:bg-[#121212] transition-colors">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h1 class="heading-border text-center text-3xl md:text-4xl font-bold dark:text-gray-100">
            Chi Siamo
          </h1>
        </div>

        <h2 class="text-2xl font-bold mb-6 text-pavesa-dark dark:text-gray-100 uppercase tracking-wide">PA.VE.SA. srl</h2>

        <p class="mb-6 text-lg leading-relaxed dark:text-gray-300">
          La Società <strong>PA.VE.SA. srl</strong> nasce nel maggio del 2008 dopo essersi evoluta dalla precedente ditta individuale
          <strong>P.V.S.</strong> (Pavimenti Verniciatura Sabbiatura), che operava con successo nel settore dal 2005.
        </p>

        <p class="mb-6 text-lg leading-relaxed dark:text-gray-300">
          L'azienda è specializzata nella fornitura di <strong>servizi industriali</strong> di altissima qualità,
          con particolare focus su:
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors">
            <h3 class="text-xl font-bold mb-3 text-pavesa-dark dark:text-gray-100 flex items-center">
              <i class="fas fa-layer-group text-pavesa-yellow mr-3"></i>
              Sabbiatura
            </h3>
            <p class="text-pavesa-gray dark:text-gray-400">
              Servizi professionali di sabbiatura per la pulizia dei metalli e la preparazione delle superfici,
              utilizzando tecniche di sabbiatura a secco e ad umido.
            </p>
          </div>

          <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors">
            <h3 class="text-xl font-bold mb-3 text-pavesa-dark dark:text-gray-100 flex items-center">
              <i class="fas fa-paint-roller text-pavesa-yellow mr-3"></i>
              Verniciatura
            </h3>
            <p class="text-pavesa-gray dark:text-gray-400">
              Verniciatura industriale con prodotti acrilici bicomponenti e altri rivestimenti specializzati,
              applicati con sistemi airless ad alta pressione.
            </p>
          </div>

          <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors">
            <h3 class="text-xl font-bold mb-3 text-pavesa-dark dark:text-gray-100 flex items-center">
              <i class="fas fa-flask text-pavesa-yellow mr-3"></i>
              Vetrificazione
            </h3>
            <p class="text-pavesa-gray dark:text-gray-400">
              Applicazione di prodotti vetrificanti per la protezione e la valorizzazione di diverse superfici,
              garantendo durata e resistenza nel tempo.
            </p>
          </div>

          <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors">
            <h3 class="text-xl font-bold mb-3 text-pavesa-dark dark:text-gray-100 flex items-center">
              <i class="fas fa-road text-pavesa-yellow mr-3"></i>
              Pavimentazioni
            </h3>
            <p class="text-pavesa-gray dark:text-gray-400">
              Installazione di pavimentazioni industriali e civili utilizzando resine flessibili e materiali ad alte prestazioni,
              progettate per resistere ad un uso intensivo.
            </p>
          </div>
        </div>

        <h2 class="text-2xl font-bold mb-6 mt-12 text-pavesa-dark dark:text-gray-100 uppercase tracking-wide">La Nostra Area di Copertura</h2>

        <p class="mb-6 text-lg leading-relaxed dark:text-gray-300">
          PA.VE.SA. srl opera in tutto il <strong>Centro e Sud Italia</strong>, con particolare competenza nelle seguenti regioni:
        </p>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium dark:text-gray-200">Toscana</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium dark:text-gray-200">Lazio</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium dark:text-gray-200">Umbria</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium dark:text-gray-200">Abruzzo</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium dark:text-gray-200">Marche</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium dark:text-gray-200">Emilia Romagna</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium dark:text-gray-200">Campania</p>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-[#1e1e1e] rounded transition-colors">
            <i class="fas fa-map-marker-alt text-pavesa-yellow text-2xl mb-2"></i>
            <p class="font-medium dark:text-gray-200">Molise</p>
          </div>
        </div>

        <h2 class="text-2xl font-bold mb-6 mt-12 text-pavesa-dark dark:text-gray-100 uppercase tracking-wide">Certificazioni</h2>

        <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors mb-8">
          <ul class="space-y-3">
            <li class="flex items-start">
              <i class="fas fa-certificate text-pavesa-yellow mt-1 mr-3"></i>
              <div>
                <strong class="dark:text-gray-100">Applicatore Fiduciario Master Builder Solutions SPA</strong>
                <p class="text-sm text-pavesa-gray dark:text-gray-400">
                  Certificazione ufficiale per l'applicazione di prodotti professionali
                  <a href="https://drive.google.com/file/d/1GXa87AhOE2FXgT4SmnZbZUoJ5bfCjj8c/view?usp=sharing" target="_blank" rel="noopener noreferrer" class="text-pavesa-yellow hover:underline">
                    (visualizza certificato)
                  </a>
                </p>
              </div>
            </li>
            <li class="flex items-start">
              <i class="fas fa-certificate text-pavesa-yellow mt-1 mr-3"></i>
              <div>
                <strong class="dark:text-gray-100">Certificazione ISO 9001:2015</strong>
                <p class="text-sm text-pavesa-gray dark:text-gray-400">
                  Sistema di Gestione per la Qualità
                  <a href="https://drive.google.com/file/d/1p6e15c3SCmJzdwixfIn_o9XDoDYJ4riO/view?usp=sharing" target="_blank" rel="noopener noreferrer" class="text-pavesa-yellow hover:underline">
                    (visualizza certificato)
                  </a>
                </p>
              </div>
            </li>
            <li class="flex items-start">
              <i class="fas fa-certificate text-pavesa-yellow mt-1 mr-3"></i>
              <div>
                <strong class="dark:text-gray-100">Certificazione Lavori Pubblici</strong>
                <p class="text-sm text-pavesa-gray dark:text-gray-400">
                  Autorizzata per progetti nel settore pubblico
                  <a href="https://drive.google.com/file/d/11H88XQCzZuQ3CwnPL-HGOQ18H_UZNBvU/view?usp=sharing" target="_blank" rel="noopener noreferrer" class="text-pavesa-yellow hover:underline">
                    (visualizza certificato)
                  </a>
                </p>
              </div>
            </li>
          </ul>
        </div>

        <h2 class="text-2xl font-bold mb-6 mt-12 text-pavesa-dark dark:text-gray-100 uppercase tracking-wide">I Nostri Clienti per Settore</h2>

        <p class="mb-6 text-lg leading-relaxed dark:text-gray-300">
          Nel corso degli anni, PA.VE.SA. srl ha consolidato la propria reputazione collaborando con importanti realtà nei principali settori industriali:
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors">
            <h3 class="text-lg font-bold mb-4 text-pavesa-dark dark:text-gray-100 flex items-center border-b pb-2 border-pavesa-yellow">
              <i class="fas fa-industry text-pavesa-yellow mr-2"></i>
              Automotive & Industriale
            </h3>
            <ul class="space-y-2 text-sm">
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Stellantis</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Bridgestone</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Leonardo SPA</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> ArcelorMittal</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Mecal</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Grifal</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Italpannelli</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Idea Concreting</li>
            </ul>
          </div>

          <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors">
            <h3 class="text-lg font-bold mb-4 text-pavesa-dark dark:text-gray-100 flex items-center border-b pb-2 border-pavesa-yellow">
              <i class="fas fa-wine-glass-alt text-pavesa-yellow mr-2"></i>
              Enologico & Alimentare
            </h3>
            <ul class="space-y-2 text-sm">
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Newlat Food SPA</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Cantine San Marzano</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Cantina Tollo</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Cantina Farnese</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Tenuta Ulisse</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Umani Ronchi</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> La Molisana</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Formec Biffi</li>
            </ul>
          </div>

          <div class="bg-gray-50 dark:bg-[#1e1e1e] p-6 rounded-lg transition-colors">
            <h3 class="text-lg font-bold mb-4 text-pavesa-dark dark:text-gray-100 flex items-center border-b pb-2 border-pavesa-yellow">
              <i class="fas fa-subway text-pavesa-yellow mr-2"></i>
              Infrastrutture & Pubblico
            </h3>
            <ul class="space-y-2 text-sm">
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Trenitalia</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Sorgenia Power</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Comune di Ancona</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Comune di Treviso</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> Comune di Ferrara</li>
              <li class="flex items-center dark:text-gray-300"><i class="fas fa-check-circle text-pavesa-yellow mr-2"></i> CIR & Cogedi</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Client Logos Section -->
  <ClientLogos lang="it" />

</BaseLayout>
