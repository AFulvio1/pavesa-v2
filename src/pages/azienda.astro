              <li class="flex items-center"><i class="fas fa-check text-pavesa-yellow mr-2"></i> MOLINO VILLA ROMITI - FORLÌ (FC)</li>
              <li class="flex items-center"><i class="fas fa-check text-pavesa-yellow mr-2"></i> CANTINA PROGRESSO AGRICOLO - CRECCHIO (CH)</li>
              <li class="flex items-center"><i class="fas fa-check text-pavesa-yellow mr-2"></i> MOLINO E RISERIA F.LLI MARTINI - VIGASIO (VR)</li>
              <li class="flex items-center"><i class="fas fa-check text-pavesa-yellow mr-2"></i> SOC. COOP. AGRICOLA RIPA TEATINA - RIPA TEATINA (CH)</li>
              <li class="flex items-center"><i class="fas fa-check text-pavesa-yellow mr-2"></i> CANTINA SOCIALE VILLAMAGNA - VILLAMAGNA (CH)</li>
              <li class="flex items-center"><i class="fas fa-check text-pavesa-yellow mr-2"></i> CANTINA SAN MICHELE ARCANGELO - VASTO (CH)</li>
              <li class="flex items-center"><i class="fas fa-check text-pavesa-yellow mr-2"></i> AZIENDA AGRICOLA ILLUMINATI S.S.A. - CONTROGUERRA (TE)</li>
              <li class="flex items-center"><i class="fas fa-check text-pavesa-yellow mr-2"></i> CANTINA CLITERNIA - CAMPOMARINO (CB)</li>
              <li class="flex items-center"><i class="fas fa-check text-pavesa-yellow mr-2"></i> CANTINA DI VENOSA (PZ)</li>
              <li class="flex items-center"><i class="fas fa-check text-pavesa-yellow mr-2"></i> CANTINA SANGRO</li>
              <li class="flex items-center"><i class="fas fa-check text-pavesa-yellow mr-2"></i> CANTINA SAN GIACOMO - ROCCA SAN GIOVANNI (CH)</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
