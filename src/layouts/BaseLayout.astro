---
import { ViewTransitions } from 'astro:transitions';
import SkipLink from '../components/SkipLink.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { getAlternateLanguagePath } from '../i18n/utils';
import '@fontsource/outfit/400.css';
import '@fontsource/outfit/500.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/700.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  keywords?: string[];
  lang?: 'it' | 'en';
  preloadImage?: string;
}

const {
  title,
  description = 'Pavimenti, Verniciatura, Sabbiatura e Impermeabilizzazione',
  keywords = [],
  lang = 'it',
  preloadImage
} = Astro.props;

const siteUrl = 'https://www.pavesasrl.it';
const currentUrl = new URL(Astro.url.pathname, siteUrl);

const alternatePath = getAlternateLanguagePath(Astro.url.pathname, lang);
const alternateItPath = lang === 'it' ? Astro.url.pathname : alternatePath;
const alternateEnPath = lang === 'en' ? Astro.url.pathname : alternatePath;
const alternateItUrl = new URL(alternateItPath, siteUrl).toString();
const alternateEnUrl = new URL(alternateEnPath, siteUrl).toString();
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords.length > 0 && (
      <meta name="keywords" content={keywords.join(', ')} />
    )}
    <link rel="canonical" href={currentUrl} />
    <link rel="alternate" hreflang="it" href={alternateItUrl} />
    <link rel="alternate" hreflang="en" href={alternateEnUrl} />
    <link rel="alternate" hreflang="x-default" href={alternateItUrl} />

    {preloadImage && (
      <link rel="preload" href={preloadImage} as="image" fetchpriority="high" />
    )}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}/logo-pavesa.png`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={currentUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/logo-pavesa.png`} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- FontAwesome Asynchronous Load for Lighthouse Performance -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" /></noscript>

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "PA.VE.SA. srl",
      "url": siteUrl,
      "logo": `${siteUrl}/logo.png`,
      "description": "Pavimenti, Verniciatura, Sabbiatura e Impermeabilizzazione",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "IT"
      },
      "sameAs": [
        "https://www.linkedin.com/company/pavesa/",
        "https://www.facebook.com/Pavesa-Srl-1532544440319105",
        "https://www.instagram.com/pavesasrl/"
      ]
    })} />

    <ViewTransitions />

    <!-- Dark mode script - must be in head to prevent flash -->
    <script is:inline>
      // Apply theme immediately to prevent flash
      (function() {
        const theme = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>

    <!-- Preserve dark mode during View Transitions -->
    <script is:inline>
      document.addEventListener('astro:before-swap', (event) => {
        const theme = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          event.newDocument.documentElement.classList.add('dark');
        }
      });
    </script>
  </head>

  <body class="font-sans text-pavesa-dark dark:text-gray-200 dark:bg-[#121212] transition-colors">
    <SkipLink lang={lang} />

    <div id="all">
      <Navbar lang={lang} />

      <main id="main-content" tabindex="-1">
        <slot />
      </main>

      <Footer lang={lang} />
    </div>

    <!-- Cookie Consent Banner -->
    <CookieConsent lang={lang} />

    <!-- Google Analytics (GDPR/GPDP compliant conditional loading & performance optimization) -->
    <script is:inline>
      (function() {
        let loaded = false;
        
        function loadGA() {
          if (loaded) return;
          
          const consentRaw = localStorage.getItem('pavesa-cookie-consent');
          if (!consentRaw) return;
          
          try {
            const consent = JSON.parse(consentRaw);
            if (!consent.analytics) return;
          } catch (e) {
            return;
          }
          
          loaded = true;
          
          const script = document.createElement('script');
          script.async = true;
          script.src = 'https://www.googletagmanager.com/gtag/js?id=G-RFBRL6FWS8';
          document.head.appendChild(script);

          window.dataLayer = window.dataLayer || [];
          window.gtag = function() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', 'G-RFBRL6FWS8', {
            'page_path': window.location.pathname
          });
        }

        // Deferred loading to preserve Lighthouse score when consent is present
        function tryDeferredLoad() {
          const consentRaw = localStorage.getItem('pavesa-cookie-consent');
          if (!consentRaw) return;
          
          try {
            const consent = JSON.parse(consentRaw);
            if (consent.analytics) {
              const timeout = setTimeout(loadGA, 3500);
              const triggerEvents = ['scroll', 'keydown', 'mousemove', 'touchstart', 'click'];
              const loadHandler = () => {
                clearTimeout(timeout);
                loadGA();
                triggerEvents.forEach(evt => window.removeEventListener(evt, loadHandler));
              };
              triggerEvents.forEach(evt => {
                window.addEventListener(evt, loadHandler, { once: true, passive: true });
              });
            }
          } catch (e) {}
        }

        // Listen for consent updates
        window.addEventListener('cookie-consent-updated', (e) => {
          if (e.detail && e.detail.analytics) {
            loadGA();
          }
        });

        // Initialize on current page load
        tryDeferredLoad();

        // Support Astro View Transitions page tracking
        document.addEventListener('astro:page-load', () => {
          if (window.gtag) {
            window.gtag('config', 'G-RFBRL6FWS8', {
              'page_path': window.location.pathname
            });
          } else {
            tryDeferredLoad();
          }
        });
      })();
    </script>
  </body>
</html>

<style>
  /* Ensure full height layout */
  html, body {
    height: 100%;
  }

  #all {
    min-height: 100%;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  /* Rimuovi focus outline dal main quando cliccato */
  main:focus {
    outline: none;
  }
</style>
